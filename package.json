{
  "name": "@nessielabs/nessie-openclaw",
  "version": "0.1.0",
  "type": "module",
  "description": "Native OpenClaw plugin for Nessie context.",
  "license": "MIT-0",
  "homepage": "https://nessielabs.com",
  "repository": {
    "type": "git",
