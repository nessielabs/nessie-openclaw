{
  "id": "nessie-openclaw",
  "name": "Nessie",
  "description": "Native OpenClaw plugin for searching, reading, and writing Nessie context through hosted MCP.",
  "version": "0.1.0",
  "skills": [
    "skills/nessie"
  ],
  "setup": {
    "providers": [
      {
        "id": "nessie",
        "authMethods": [
          "api-key"
        ],
        "envVars": [
          "NESSIE_API_KEY"
        ]
      }
    ]
  },
  "uiHints": {
    "apiKey": {
      "label": "Nessie API key",
      "sensitive": true,
      "placeholder": "sk_nes_v1_...",
      "help": "Create this in Nessie Settings > API keys. Use ${NESSIE_API_KEY} to avoid storing the value inline."
    },
    "endpoint": {
      "label": "Nessie MCP endpoint",
      "placeholder": "https://mcp.nessielabs.com/mcp",
      "advanced": true,
      "help": "Override only for staging or local development."
    }
  },
  "contracts": {
    "tools": [
      "nessie_team_list",
      "nessie_integration_list",
      "nessie_list",
      "nessie_ls",
      "nessie_search",
      "nessie_read",
      "nessie_resume",
      "nessie_who_am_i",
      "nessie_check_in",
      "nessie_folders",
      "nessie_create_context",
      "nessie_edit_context",
      "nessie_rename_context",
      "nessie_move_context",
      "nessie_delete_context",
      "nessie_create_folder",
      "nessie_rename_folder",
      "nessie_delete_folder"
    ]
  },
